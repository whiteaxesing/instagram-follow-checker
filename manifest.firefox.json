{
  "manifest_version": 3,
  "name": "Insta Follow Checker",
  "version": "1.0.0",
  "description": "See who doesn't follow you back on Instagram and unfollow directly.",
  "permissions": ["activeTab"],
  "host_permissions": ["https://www.instagram.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "insta-follow-checker@franciscogm982.github.io",
      "strict_min_version": "109.0"
    }
  }
}
